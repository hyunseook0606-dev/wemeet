# ══════════════════════════════════════════════════════════════
# 위밋모빌리티 해상 리스크 플랫폼 — 환경변수 예시
# 사용법: 이 파일을 .env 로 복사 후 실제 키 입력
#
#   Windows PowerShell: Copy-Item .env.example .env
#   Mac/Linux:          cp .env.example .env
#
# 주의: .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 등록됨)
# ══════════════════════════════════════════════════════════════


# ── [필수] Google Gemini API ─────────────────────────────────
# 용도: LLM 자동 보고서 생성 (무료, 일 1,500회 한도)
# 발급: https://aistudio.google.com → Get API key
#       구글 계정만 있으면 즉시 발급, 카드 불필요
GEMINI_API_KEY=여기에_Gemini_API_키_입력


# ── [선택] 카카오 API ────────────────────────────────────────
# 용도: 항만 주변 창고·ODCY 실시간 탐색 + 경로 계산
# 발급: https://developers.kakao.com
#   1. 카카오 계정으로 로그인
#   2. 내 애플리케이션 → 애플리케이션 추가하기
#   3. 앱 이름 입력 (예: wemet-platform) → 저장
#   4. 앱 선택 → 앱 키 → REST API 키 복사
# 무료: Local API 300,000건/일, Mobility API 5,000건/일
# 두 변수에 같은 키를 넣으면 됩니다
KAKAO_REST_API_KEY=여기에_카카오_REST_API_키_입력
KAKAO_MOBILITY_KEY=여기에_카카오_REST_API_키_입력   # 위와 동일한 키


# ── [선택] 한국은행 ECOS API ─────────────────────────────────
# 용도: 환율(원/달러), 두바이유, GDP 공식 실데이터
# 발급: https://ecos.bok.or.kr/api/ → 회원가입 → API키 신청
# 없으면 Yahoo Finance(유가), frankfurter.app(환율) 자동 대체
ECOS_API_KEY=여기에_ECOS_API_키_입력


# ── [선택] 부산항만공사 BPA API ──────────────────────────────
# 용도: 부산항 컨테이너 물동량 실데이터 (2020~2024)
# 발급: https://www.data.go.kr → "부산항 컨테이너 수송통계" 검색 → 활용신청
# 없으면 BPA 홈페이지 Excel + 계절분해로 자동 대체
BPA_API_KEY=여기에_BPA_API_키_입력


# ── [선택] Claude (Anthropic) API ────────────────────────────
# 용도: LLM 자동 보고서 (Gemini 없을 때 대안)
# 발급: https://console.anthropic.com/settings/keys
# 유료 (~월 $5), Gemini 무료 키가 있으면 불필요
ANTHROPIC_API_KEY=여기에_Anthropic_API_키_입력


# ── [참고] 공공데이터포털 KCCI API ───────────────────────────
# 용도: KCCI 운임지수 실시간 API (선택 — XLS 파일로도 대체 가능)
# 발급: https://www.data.go.kr/data/15131881/openapi.do
# DATA_GO_KR_KEY=여기에_공공데이터포털_키_입력
